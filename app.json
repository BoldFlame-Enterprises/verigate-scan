{
  "expo": {
    "name": "VeriGate Scan",
    "slug": "verigate-scan",
    "version": "1.0.0",
    "owner": "boldflame-enterprises",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "verigate-scan",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#059669"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.verigate.scan",
      "infoPlist": {
        "NSCameraUsageDescription": "VeriGate Scan needs camera access to scan QR codes for access control verification."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#059669"
      },
      "package": "com.verigate.scan",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "VeriGate Scan needs camera access to scan QR codes for access control verification."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#059669"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "apiBaseUrl": "http://localhost:3000/api",
      "demoMode": false,
      "eas": {
        "projectId": "f87b2c52-b3c6-4af0-8c83-21756a665b87"
      }
    }
  }
}
